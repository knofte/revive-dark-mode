<?xml version="1.0" encoding="ISO-8859-1" ?>
<?xml-stylesheet type="text/xsl" href=""?>

<plugin>
    <name>rvDarkMode</name>
    <displayName>Revive Dark Mode</displayName>
    <creationDate>2026-04-05</creationDate>
    <author>Community</author>
    <authorEmail>noreply@example.com</authorEmail>
    <authorUrl>https://github.com/knofte/revive-dark-mode</authorUrl>
    <license>GPLv2</license>
    <description>Dark mode theme for Revive Adserver admin UI</description>
    <version>1.0.0</version>
    <oxversion>5.0.0</oxversion>
    <extends>admin</extends>

    <install>
        <files>
            <file path="{ADMINPATH}/css/">dark-mode.css</file>
            <file path="{ADMINPATH}/">rvDarkMode.class.php</file>
        </files>

        <components>
           <component>
                <name>rvDarkMode</name>
                <hook>registerUiListeners</hook>
           </component>
        </components>
    </install>
</plugin>
